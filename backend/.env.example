# Porta do servidor local
PORT=3000

# Ambiente: development | test | production
NODE_ENV=development

# String de conexão do PostgreSQL (Neon, Supabase, RDS, etc.)
# Dica: no Neon, use a connection string "pooled" (com "-pooler" no host) para uso serverless.
# Exemplo Neon: postgresql://user:password@ep-xxxx-pooler.sa-east-1.aws.neon.tech/taskmanager?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/taskmanager

# Segredo usado para assinar os JWT. Gere um valor forte em produção, ex: `openssl rand -hex 32`
JWT_SECRET=troque-este-valor-por-um-segredo-forte
JWT_EXPIRES_IN=7d

# Origem permitida para CORS (URL do frontend)
FRONTEND_URL=http://localhost:5173

# OpenTelemetry / Jaeger
OTEL_ENABLED=true
OTEL_SERVICE_NAME=task-manager-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
